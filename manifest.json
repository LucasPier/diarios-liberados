{
  "name": "Diarios Liberados",
  "short_name": "diarios-liberados",
  "description": "Mejora visualización de diarios online",
  "version": "1.0",
  "author": "Lucas Pier",
  "homepage_url": "https://github.com/LucasPier/diarios-liberados",
  "manifest_version": 3,
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://*.lacapital.com.ar/*",
    "*://*.flipbook.com.ar/*",
    "*://cdn.wyleex.com/*",
    "*://*.lavoz.com.ar/*",
    "*://d323qqnnjmo65t.cloudfront.net/*",
    "*://*.clarin.com/*",
    "*://*.lanacion.com.ar/*",
    "*://*.infobae.com/*",
    "*://*.ellitoral.com/*",
    "*://*.puertonegocios.com/*",
    "*://*.rosario3.com/*",
    "*://*.lapoliticaonline.com/*",
    "*://*.pagina12.com.ar/*",
    "*://*.cronista.com/*",
    "*://*.ambito.com/*",
    "*://*.eldestapeweb.com/*",
    "*://*.perfil.com/*",
    "*://*.canalnet.tv/*",
    "*://*.batimes.com.ar/*",
    "*://*.ole.com.ar/*",
    "*://*.elciudadanoweb.com/*",
    "*://*.viapais.com.ar/*",
    "*://*.diariopopular.com.ar/*",
    "*://*.eltrecetv.com.ar/*",
    "*://*.radiomitre.com.ar/*",
    "*://*.tycsports.com/*",
    "*://*.ciudad.com.ar/*",
    "*://*.tn.com.ar/*",
    "*://*.cienradios.com/*",
    "*://*.kenja.tech/*",
    "*://*.minutouno.com/*",
    "*://imasdk.googleapis.com/*"
  ],
  "background": {
    "service_worker": "sw.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "recursos/suscripciones_lavoz.svg",
        "recursos/crown-icon_lavoz.svg",
        "recursos/crown-fill-black_lavoz.svg",
        "recursos/socios_p12.svg",
        "recursos/socios_v2_p12.svg"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "/imagenes/favicon-16x16.png",
      "32": "/imagenes/favicon-32x32.png",
      "96": "/imagenes/favicon-96x96.png",
      "144": "/imagenes/favicon-144x144.png"
    }
  },
  "icons": {
    "16": "/imagenes/favicon-16x16.png",
    "32": "/imagenes/favicon-32x32.png",
    "96": "/imagenes/favicon-96x96.png",
    "144": "/imagenes/favicon-144x144.png"
  },
  "content_scripts": [
    {
      "js": [
        "js/clarinpre.js"
      ],
      "css": [
        "css/clarin.css"
      ],
      "matches": [
        "*://*.clarin.com/*",
        "*://*.ole.com.ar/*"
      ],
      "run_at": "document_start"
    },
    {
      "js": [
